{
  "expo": {
    "name": "AZVIO",
    "slug": "azvio",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.azvio.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "استخدم بصمة الوجه لفتح تطبيق AZVIO بسرعة وأمان",
        "NSMicrophoneUsageDescription": "يحتاج سند إذن الميكروفون لتسجيل رسائلك الصوتية والرد عليك",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "package": "co.azvio.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "AZVIO",
      "shortName": "AZVIO",
      "description": "إدارة أعمال التصوير الجوي والمونتاج مع سند AI",
      "backgroundColor": "#FFFFFF",
      "themeColor": "#3E9194",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "ar",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications",
      "expo-local-authentication",
      [
        "expo-audio",
        {
          "microphonePermission": "يحتاج سند إذن الميكروفون لتسجيل رسائلك الصوتية والرد عليك"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5a221446-693e-42a1-96ba-bdfc679822d8"
      }
    }
  }
}
